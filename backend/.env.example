APP_NAME="Atomic Habits API"
ENVIRONMENT="dev"
API_PREFIX="/api/v1"
JWT_SECRET="change-me-super-secret"
JWT_EXP_MINUTES=20160

DATABASE_URL="sqlite+aiosqlite:///./atomic_habits.db"
ALLOW_LOCAL_AUTH=true

TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBAPP_URL="https://<your-github-user>.github.io/<repo>/"
DEFAULT_TIMEZONE="Europe/Moscow"

OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"
OPENROUTER_SITE_URL="http://localhost"
OPENROUTER_SITE_NAME="Atomic Habits Coach"
MAX_DAILY_TOKENS=8000
REQUIRE_PAID_ACCESS=true
DEV_AUTO_PAID=true
